{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["src/**", "pom.xml", "Dockerfile"]
  },
  "deploy": {
    "startCommand": "java -jar target/*.jar",
    "healthcheckPath": "/api/auth/login",
    "restartPolicyType": "ON_FAILURE"
  }
}
